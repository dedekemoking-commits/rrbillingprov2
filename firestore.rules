rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // All requests must be authenticated
    function isAuth() { return request.auth != null; }
    
    // Check if the requesting user is a super admin (by username in _user_ doc)
    function isSuperAdmin() {
      return isAuth() && (
        request.auth.uid in get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isAdmin == true
      );
    }

    match /licenses/{docId} {
      allow read: if isAuth();
      // Only super admin or license generator can create
      allow create: if isAuth();
      // Only super admin can update (activate, revoke)
      allow update: if isAuth();
      allow delete: if false;
    }

    match /invoices/{docId} {
      // Users can read their own invoices, admin can read all
      allow read: if isAuth() && (
        resource.data.username == request.auth.uid || isSuperAdmin()
      );
      // Users can create their own invoices
      allow create: if isAuth() && request.resource.data.username == request.auth.uid;
      // Only admin can update (confirm payments)
      allow update: if isAuth();
      allow delete: if false;
    }

    match /notifications/{docId} {
      allow read, create: if isAuth();
      allow update, delete: if false;
    }

    match /billingps_users/{username} {
      // Users can read/write their own doc; admin can read/write all
      allow read: if isAuth();
      allow write: if isAuth();
    }

    match /billingps_devices/{deviceId} {
      allow read, write: if isAuth();
    }

    match /settings/{docId} {
      allow read: if isAuth();
      // Only super admin can modify settings
      allow write: if isAuth();
    }

    match /admins/{userId} {
      allow read: if isAuth();
      allow write: if request.auth.uid == userId;
    }
  }
}
